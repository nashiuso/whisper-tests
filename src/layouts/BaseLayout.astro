---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = '嘘無し, whisper tests',
  description = 'whisper tests, minimal fingerprint whisper lab, built with Astro. astryx void, practical echoes.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Copyright (c) 2026, Nashi Uso, (嘘無し). -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f5f5f3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#101010" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
